# ============================================================================
# run-sous-bpm — local development configuration
# ============================================================================
# Copy this file to .env at the repo root and fill in the secrets.
# Loaded by:
#   - Rust backend via dotenvy (walks up the dir tree to find this file)
#   - docker-compose.yml (dev) via env_file: .env
# Frontend has its own frontend/.env (Vite build-time vars, prefixed VITE_).
#
# In PROD: no .env is used. Secrets live as files under
# /etc/run-sous-bpm/secrets/, mounted into containers via Docker secrets
# (see docker-compose.prod.yml). Public config is set in `environment:` blocks.
# ============================================================================

# ----- Database ------------------------------------------------------------
DB_PASSWORD=change_me_strong_password
DB_NAME=run_sous_bpm
DB_USER=run_sous_bpm
DB_PORT=5433
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}

# ----- Redis ---------------------------------------------------------------
# Local Redis: no auth needed
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:${REDIS_PORT}

# ----- Backend -------------------------------------------------------------
PORT=3000
HOST=http://127.0.0.1${PORT}
COOKIE_SECURE=false
REDIRECT_ENDPOINT=/api/oauth/callback
REDIRECT_URI=${HOST}${REDIRECT_ENDPOINT}
FRONTEND_URL=${HOST}

# ----- Token encryption ----------------------------------------------------
# Generate with: openssl rand -hex 32 > encryption.key
ENCRYPTION_KEY_FILE=./encryption.key

# ----- Last.fm -------------------------------------------------------------
# Get key at: https://www.last.fm/api/account/create
LAST_FM_API_KEY=

# ----- Strava OAuth --------------------------------------------------------
# Register app at: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_BASE_URL=https://www.strava.com
STRAVA_AUTH_URL=${STRAVA_BASE_URL}/oauth/authorize
STRAVA_TOKEN_URL=${STRAVA_BASE_URL}/oauth/token
STRAVA_API_URL=https://www.strava.com/api/v3

# ----- Spotify OAuth -------------------------------------------------------
# Register app at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_BASE_URL=https://accounts.spotify.com
SPOTIFY_AUTH_URL=${SPOTIFY_BASE_URL}/authorize
SPOTIFY_TOKEN_URL=${SPOTIFY_BASE_URL}/api/token
SPOTIFY_API_URL=https://api.spotify.com/v1

# ----- Logging -------------------------------------------------------------
# LOG_FORMAT=json
