# Database
DB_PASSWORD=change_me_strong_password
DB_NAME=run_sous_bpm
DB_USER=run_sous_bpm
DB_PORT=5433
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}

# Redis
REDIS_PASSWORD=
REDIS_URL=redis://127.0.0.1:6379
# Production: redis://:${REDIS_PASSWORD}@redis:6379

# Backend
PORT=3000
HOST=http://127.0.0.1
REDIRECT_ENDPOINT=/api/oauth/callback
REDIRECT_URI=${HOST}:${PORT}${REDIRECT_ENDPOINT}
FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false

# Token encryption key file (generate with: openssl rand -hex 32 > encryption.key)
ENCRYPTION_KEY_FILE=/path/to/encryption.key

# Last.fm
LAST_FM_API_KEY=your_lastfm_api_key

# Strava OAuth
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_BASE_URL=https://www.strava.com
STRAVA_AUTH_URL=${STRAVA_BASE_URL}/oauth/authorize
STRAVA_TOKEN_URL=${STRAVA_BASE_URL}/oauth/token
STRAVA_API_URL=https://www.strava.com/api/v3

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_BASE_URL=https://accounts.spotify.com
SPOTIFY_AUTH_URL=${SPOTIFY_BASE_URL}/authorize
SPOTIFY_TOKEN_URL=${SPOTIFY_BASE_URL}/api/token

# Logging (json or pretty)
# LOG_FORMAT=json
